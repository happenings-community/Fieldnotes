{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProofPoll",
  "version": "0.2.0-beta19",
  "identifier": "com.proofpoll.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ProofPoll",
        "width": 900,
        "height": 700,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/proofpoll-holochain",
      "binaries/proofpoll-lair-keystore"
    ],
    "resources": [
      "resources/proofpoll_v1_3_happ.happ"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": null,
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
