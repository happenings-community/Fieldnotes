# Dependencies
node_modules/

# Build outputs
dist/
tmp/
src-tauri/target/
dna/target/

# DNA build outputs (all versions)
dna/target/
dna/workdir/*.wasm
dna/workdir/*.dna
dna/workdir/*.happ
dna/v1.1/target/
dna/v1.1/workdir/*.wasm
dna/v1.1/workdir/*.dna
dna/v1.1/workdir/*.happ
dna/v1.2/target/
dna/v1.2/workdir/*.wasm
dna/v1.2/workdir/*.dna
dna/v1.2/workdir/*.happ
dna/Cargo.lock
dna/v1.1/Cargo.lock
dna/v1.2/Cargo.lock

# Binaries (platform-specific, not committed)
src-tauri/binaries/

# hApp bundles (built from DNA source)
src-tauri/resources/*.happ

# IDE
.idea/
.vscode/
*.swp
*.swo

# Environment (contains client_id — use .env.example as template)
.env
.env.local

# OS
.DS_Store
Thumbs.db

# Qwik
server/
.vercel/
.netlify/
dna/v1.3/target/

# Guarded-patch delivery scripts (throwaway; their effects are committed
# in the files they edit, never as source themselves)
patch_*.py

# Tauri-generated schemas (regenerated on build)
src-tauri/gen/schemas/

# Guarded-patch dry-run artefacts
*.patched
