# ── Flowsta identity (OAuth) ──────────────────────────────────────
# Register your app at dev.flowsta.com to get a client_id
VITE_FLOWSTA_CLIENT_ID=your_client_id_here

# ── Holochain bootstrap / signal / relay (compile-time) ──────────
# Read by src-tauri/src/conductor.rs at compile time. Leave unset
# during dev to use the public Holochain test bootstrap (no setup
# required). Set for production builds to point at your own
# bootstrap (or, once Flowsta opens bootstrap-as-a-service, the
# Flowsta one). See "Network Infrastructure" in README.md.
#
# PROOFPOLL_BOOTSTRAP_URL=https://your-bootstrap.example.com
# PROOFPOLL_SIGNAL_URL=wss://your-bootstrap.example.com
# PROOFPOLL_RELAY_URL=https://your-bootstrap.example.com./
#
# PROOFPOLL_AUTH_MATERIAL is opaque bytes sent to the bootstrap's
# /authenticate endpoint. Only set if your bootstrap requires
# --authentication-hook-server (e.g. Flowsta's).
# PROOFPOLL_AUTH_MATERIAL=<base64url of `{"client_id":"flowsta_app_..."}`>
